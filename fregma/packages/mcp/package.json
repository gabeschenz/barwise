{
  "name": "@fregma/mcp",
  "version": "0.2.1",
  "description": "MCP server for ORM 2 modeling capabilities",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "bin": {
    "fregma-mcp": "./dist/bundle/index.cjs"
  },
  "files": [
    "dist/bundle/index.cjs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gabeschenz/fregma",
    "directory": "fregma/packages/mcp"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ORM",
    "Object-Role Modeling",
    "data modeling",
    "conceptual modeling"
  ],
  "license": "SEE LICENSE IN ../../LICENSE",
  "author": "Gabe Schenz",
  "scripts": {
    "build": "tsc",
    "bundle": "node esbuild.mjs",
    "prepublishOnly": "node esbuild.mjs",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint src/ tests/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fregma/core": "0.3.0",
    "@fregma/diagram": "0.2.0",
    "@fregma/llm": "0.3.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "esbuild": "^0.27.3",
    "vitest": "^3.0.0"
  }
}
