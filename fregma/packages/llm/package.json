{
  "name": "@fregma/llm",
  "version": "0.2.2",
  "private": true,
  "description": "LLM-powered transcript extraction for ORM models",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
