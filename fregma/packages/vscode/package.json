{
  "name": "fregma-vscode",
  "displayName": "Fregma ORM Modeler",
  "description": "ORM 2 modeling tool for data engineers and architects",
  "version": "0.2.0",
  "private": true,
  "publisher": "fregma",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:yaml",
    "workspaceContains:**/*.orm.yaml",
    "workspaceContains:**/*.orm-project.yaml"
  ],
  "main": "./dist/client/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "orm.newProject",
        "title": "New Project",
        "category": "ORM"
      },
      {
        "command": "orm.validateModel",
        "title": "Validate Model",
        "category": "ORM"
      },
      {
        "command": "orm.verbalize",
        "title": "Verbalize Model",
        "category": "ORM"
      },
      {
        "command": "orm.showDiagram",
        "title": "Show Diagram",
        "category": "ORM"
      },
      {
        "command": "orm.import",
        "title": "Import...",
        "category": "ORM"
      },
      {
        "command": "orm.export",
        "title": "Export...",
        "category": "ORM"
      }
    ],
    "configuration": {
      "title": "Fregma ORM",
      "properties": {
        "fregma.llmProvider": {
          "type": "string",
          "enum": [
            "copilot",
            "anthropic"
          ],
          "default": "copilot",
          "description": "LLM provider for transcript extraction. 'copilot' uses your GitHub Copilot subscription (no API key needed). 'anthropic' uses the Anthropic API directly."
        },
        "fregma.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key (only used when llmProvider is 'anthropic'). Leave empty to use the ANTHROPIC_API_KEY environment variable."
        },
        "fregma.anthropicModel": {
          "type": "string",
          "default": "claude-sonnet-4-5-20250929",
          "description": "Anthropic model ID (only used when llmProvider is 'anthropic')."
        },
        "fregma.copilotModelFamily": {
          "type": "string",
          "default": "",
          "description": "Copilot model family to prefer (e.g. 'gpt-4o', 'claude-sonnet'). Leave empty to use the default available model."
        }
      }
    },
    "languages": [
      {
        "id": "orm-yaml",
        "aliases": [
          "ORM YAML"
        ],
        "extensions": [
          ".orm.yaml"
        ],
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:unit": "vitest run",
    "pretest:integration": "tsc -p tsconfig.test.json",
    "test:integration": "vscode-test"
  },
  "dependencies": {
    "@fregma/core": "0.2.0",
    "@fregma/diagram": "0.1.0",
    "@fregma/llm": "0.2.1",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.0.8",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.2.3",
    "@types/vscode": "^1.93.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "mocha": "^11.7.5",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
