		<orm:ModelNotes>
			<orm:ModelNote id="_9E48BF4D-8BB5-4F96-8324-0F7E699A7903">
				<orm:Text>TODO</orm:Text>
				<orm:ReferencedBy>
					<orm:ObjectType ref="_6693D133-C04F-46C1-9D2B-AE5D163570F6" />
				</orm:ReferencedBy>
			</orm:ModelNote>
			<orm:ModelNote id="_530DDF8D-33C0-4B6A-B45D-2B9D2653043C">
				<orm:Text>Listing is a digital representation of something
					that is for sale. This could be something else
					besides a Lot. When selling elsewhere (i.e., not
					at an auction), Listing can list ConsignmentAssets. </orm:Text>
			</orm:ModelNote>
			<orm:ModelNote id="_3654F565-281E-48D6-A8F6-B0CEF0516106">
				<orm:Text>Replacement of the legacy lot grouping</orm:Text>
				<orm:ReferencedBy>
					<orm:FactType ref="_143796B2-709A-4421-BBB6-5C42A2E01CE3" />
				</orm:ReferencedBy>
			</orm:ModelNote>
			<orm:ModelNote id="_339B633F-CAF3-4E90-BC6E-5F56BA486A3B">
				<orm:Text>Service: the seller needs to pay for it. Eg.:
					* listing cost
					* lien search cost
					* stock cost
					* painting cost</orm:Text>
				<orm:ReferencedBy>
					<orm:ObjectType ref="_6693D133-C04F-46C1-9D2B-AE5D163570F6" />
				</orm:ReferencedBy>
			</orm:ModelNote>
			<orm:ModelNote id="_7563C8B0-EA24-4434-A536-526F20D09AA3">
				<orm:Text>Taxosphere-related concepts below</orm:Text>
			</orm:ModelNote>
			<orm:ModelNote id="_6A048F2A-C40D-49D9-A7DA-E0A256432354">
				<orm:Text>This is something come back to later</orm:Text>
				<orm:ReferencedBy>
					<orm:FactType ref="_FAA2028D-F664-4F5E-8033-7B1E272468FB" />
					<orm:FactType ref="_5AD00B6B-D545-4220-8093-D3EA3A334B65" />
				</orm:ReferencedBy>
			</orm:ModelNote>
			<orm:ModelNote id="_A52C139F-3D26-44ED-BEE7-7E295FC0EAAF">
				<orm:Text>Group of services that is predefined</orm:Text>
				<orm:ReferencedBy>
					<orm:ObjectType ref="_0ABE8833-302B-46AF-AFF6-34A0DA6268E3" />
				</orm:ReferencedBy>
			</orm:ModelNote>
			<orm:ModelNote id="_856DCBD5-7E39-4BA2-87BC-B03B49343E5C">
				<orm:Text>Post-sale counterpart of listing</orm:Text>
				<orm:ReferencedBy>
					<orm:ObjectType ref="_E42B67FC-09F0-4208-9BBA-DD876C489932" />
				</orm:ReferencedBy>
			</orm:ModelNote>
			<orm:ModelNote id="_0F66B300-C295-4CFC-B429-B0BCD51EB648">
				<orm:Text>This just represents that
					there are no 'empty' auctions</orm:Text>
				<orm:ReferencedBy>
					<orm:SetComparisonConstraint ref="_6AD98A5D-DE2C-48C3-B0FE-BE704B122BBC" />
				</orm:ReferencedBy>
			</orm:ModelNote>
			<orm:ModelNote id="_F13AD1CB-3F7C-43EC-BCE9-275F29272B05">
				<orm:Text>Net payout</orm:Text>
				<orm:ReferencedBy>
					<orm:ObjectType ref="_9CB4B88C-0918-48DB-9E4A-09B244CC00D3" />
				</orm:ReferencedBy>
			</orm:ModelNote>
			<orm:ModelNote id="_5C1FA3F0-D965-41D5-8684-9F712C796346">
				<orm:Text>For prediction purposes it is likely more interesting to look at the
					initial sold price

					The last sold price is interesting from a revenue perspective</orm:Text>
				<orm:ReferencedBy>
					<orm:FactType ref="_3CE2AC07-8AA0-496F-B379-E72FCE2E39AC" />
				</orm:ReferencedBy>
			</orm:ModelNote>
			<orm:ModelNote id="_0142AFBB-B1A4-4DA6-89C2-148520B991E7">
				<orm:Text>Seller GTV</orm:Text>
				<orm:ReferencedBy>
					<orm:FactType ref="_3F5DAC02-EA91-4196-9D8F-ACB9A352F9FA" />
				</orm:ReferencedBy>
			</orm:ModelNote>
			<orm:ModelNote id="_91BA3A3C-FC41-4A47-A544-930F5389891D">
				<orm:Text>The amount on the refund cannot be greater than the amount on the payment</orm:Text>
			</orm:ModelNote>
		</orm:ModelNotes>
